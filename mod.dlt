# ============================
#  Dolet Input Library
# ============================
# Comprehensive, platform-independent input handling system
# Provides unified keyboard, mouse, and gamepad input
#
# Usage: import input
module input
load input/platform
load input/keys
load input/mouse
load input/chars
load input/gamepad
load input/input

# Exported structs
export POINT
export Input
export XINPUT_GAMEPAD
export XINPUT_STATE

# Exported functions — Keyboard
export key_pressed
export key_just_pressed
export key_just_released
export shift_pressed
export ctrl_pressed
export alt_pressed
export key_to_char
export key_to_char_shifted
export input_init
export input_update

# Exported functions — Mouse
export mouse_x
export mouse_y
export mouse_delta_x
export mouse_delta_y
export mouse_pressed
export mouse_just_pressed
export mouse_just_released
export mouse_scroll
export add_scroll
export reset_scroll
export mouse_is_dragging
export mouse_drag_start_x
export mouse_drag_start_y
export mouse_drag_delta_x
export mouse_drag_delta_y
export MOUSE_LEFT
export MOUSE_RIGHT
export MOUSE_MIDDLE
export MOUSE_X1
export MOUSE_X2

# Exported functions — Typed chars (for TextInput widgets)
export input_push_typed_char
export input_typed_chars
export input_has_backspace
export input_reset_typed_chars

# Exported functions — Gamepad
export gamepad_connected
export gamepad_pressed
export gamepad_just_pressed
export gamepad_just_released
export gamepad_stick_x
export gamepad_stick_y
export gamepad_trigger
